{
  "name": "next-js-template",
  "type": "module",
  "scripts": {
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:*",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server -m 100 --db=local.db --run 'npm run db:migrate'",
    "db-server:memory": "pglite-server -m 100 --run 'npm run db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.6.1",
    "@base-ui/react": "^1.6.0",
    "@clerk/localizations": "^4.12.0",
    "@clerk/nextjs": "^7.5.11",
    "@hookform/resolvers": "^5.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@logtape/logtape": "^2.2.2",
    "@sentry/nextjs": "^10.62.0",
    "@supabase/supabase-js": "^2.110.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "next": "^16.2.9",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "^3.9.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.14.10",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/prompt-cli": "^21.2.0",
    "@commitlint/types": "^21.0.1",
    "@electric-sql/pglite-socket": "^0.2.6",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^7.14.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
