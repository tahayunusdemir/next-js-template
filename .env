# FIXME: Configure environment variables for your project

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Stripe billing (publishable key is public; secret key + webhook secret go in .env.local)
# Price ids are public and live in src/lib/plans.ts, not here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database
# Local database with PGLite, already included in the project, no Docker needed
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Supabase Realtime (chat) — public project URL + anon/publishable key. Leave blank locally:
# PGlite has no Realtime, so chat falls back to SSR refresh. Fill in to test against a Supabase
# dev project. See docs/cinepersona-docs/supabase-migration.md §6 and supabase/README.md.
# NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Next.js
NEXT_TELEMETRY_DISABLED=1
# Set to 'true' to stop forwarding browser console logs to the dev server terminal
# BROWSER_TO_TERMINAL_DISABLED=true

# Error monitoring (Sentry)
# Set to any non-empty value to disable Sentry locally (skips init in next.config.ts and instrumentation)
# NEXT_PUBLIC_SENTRY_DISABLED=true

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

######## [BEGIN] SENSITIVE DATA ######## For security reason, don't update the following variables (secret key) directly in this file.
######## Please create a new file named `.env.local`, all environment files ending with `.local` won't be tracked by Git.
######## After creating the file, you can add the following variables.
# Arcjet security
# Get your key from https://launch.arcjet.com/Q6eLbRE
# ARCJET_KEY=

# Clerk authentication
CLERK_SECRET_KEY=your_clerk_secret_key

# Stripe billing — secret key + webhook signing secret (test mode for local dev)
# Get them from https://dashboard.stripe.com/test/apikeys and the webhook settings.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# CineMatch sweep endpoint — shared bearer secret the scheduler sends to
# POST /api/cinematch/sweep. Leave blank to disable the endpoint (404).
# CINEMATCH_CRON_SECRET=

# TMDB API (films catalogue) — Read Access Token (Bearer), server-only.
# Get it from https://www.themoviedb.org/settings/api (the "API Read Access Token").
# Required to seed films (src/scripts/import-movies.ts) and render the film detail page.
# TMDB_API_READ_TOKEN=
######## [END] SENSITIVE DATA
